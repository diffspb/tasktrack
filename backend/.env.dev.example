DATABASE_URL=postgresql+asyncpg://tasktrack:tasktrack@localhost:5432/tasktrack
AUTH_STUB=true
KEYCLOAK_URL=https://auth.busypage.ru
KEYCLOAK_REALM=home
KEYCLOAK_CLIENT_ID=tasktrack
CORS_ORIGINS=["http://localhost:5173"]

# MCP-сервер для агентов (опционально)
# Создать агент-пользователя: make mcp-bootstrap
# Затем вставить UUID из вывода:
# MCP_AGENT_USER_ID=<uuid>
#
# Для нескольких агентов (prod):
# MCP_AGENTS=my-key:uuid1,another-key:uuid2

# Запустить БД:
# make db-start
# или вручную:
# docker run -d --name tasktrack-dev \
#   -e POSTGRES_DB=tasktrack -e POSTGRES_USER=tasktrack -e POSTGRES_PASSWORD=tasktrack \
#   -p 5432:5432 postgres:16-alpine
